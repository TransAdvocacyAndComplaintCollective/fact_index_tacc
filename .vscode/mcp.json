        "mantine": {
      "command": "npx",
      "args": ["@hakxel/mantine-ui-server"],
      "env": {
      }
    },
		"nodemonDocs": {
			"type": "http",
			"url": "https://gitmcp.io/remy/nodemon"
		},
		"tsNodeDocs": {
			"type": "http",
			"url": "https://gitmcp.io/TypeStrong/ts-node"
		},
		"webVitalsDocs": {
			"type": "http",
			"url": "https://gitmcp.io/GoogleChrome/web-vitals"
		},
		"eslintPluginImportDocs": {
			"type": "http",
			"url": "https://gitmcp.io/import-js/eslint-plugin-import"
		},
		"eslintPluginReactDocs": {
			"type": "http",
			"url": "https://gitmcp.io/jsx-eslint/eslint-plugin-react"
		},
		"eslintPluginReactHooksDocs": {
			"type": "http",
			"url": "https://gitmcp.io/facebook/react"
		},

		"context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "${input:context7ApiKey}"
			}
		},
		"npmSearch": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"npm-search-mcp-server"
			]
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
    "oraios/serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide",
        "--project",
        "${workspaceFolder}"
      ]
    },


        "storybook-mcp": {
      "command": "npx",
      "args": [ "storybook-mcp@latest"],
      "env": {
        "STORYBOOK_URL": "http://localhost:6007/index.json"
      }
    },
   "storybook": {
      "type": "http",
      "url": "http://localhost:6006/mcp"
    }
	},
	"inputs": [
		{
			"type": "promptString",
			"id": "context7ApiKey",
			"description": "Context7 API key (recommended; leave blank if you don’t have one)",
			"password": true
		}
	]
}