# ============================================================================
# Fact Index Server Configuration
# ============================================================================
# Copy this file to .env and update the values for your environment

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=development
PORT=5332
FRONTEND_URL=http://localhost:5173

# ============================================================================
# OpenID Federation Configuration
# ENABLE_FEDERATION controls whether to enable:
#   - OpenID Federation endpoints (/.well-known/openid-federation)
#   - OIDC Provider instances
#   - OIDC interaction routes (/interaction/*, /oidc/*)
#
# Set to 'false' to run without federation support
# ============================================================================
ENABLE_FEDERATION=true

# ENABLE_FEDERATION_PROVIDER controls OIDC Provider creation
# Set to 'false' to disable OIDC token/authorization endpoints
ENABLE_FEDERATION_PROVIDER=true

# ENABLE_FEDERATION_LOGIN controls OIDC interaction flows (login, consent)
# Set to 'false' to disable login flows (requires ENABLE_FEDERATION_PROVIDER=true to work)
ENABLE_FEDERATION_LOGIN=true

FEDERATION_ENTITY_ID=https://fact.example.com
FEDERATION_ORG_NAME=Fact Index
FEDERATION_NETWORK_NAME=United Federation of Trans Organizations
FEDERATION_CONTACT_EMAIL=admin@fact.example.com
FEDERATION_AUTHORITY_HINTS=
# Optional comma-separated fallback list of external OP entity IDs
# (legacy format, still supported)
FEDERATION_OTHER_OPS=
# Optional JSON provider matrix (preferred for many-to-many):
# FEDERATION_OPS=[{"name":"Partner A","entityId":"https://partner-a.example.com","clients":[{"id":"web","clientId":"fact-index-web","clientSecret":"secret-a","redirectUri":"http://localhost:5332/auth/federation/callback","scopes":"openid profile email"}]},{"name":"Partner B","entityId":"https://partner-b.example.com","clients":[{"id":"web","clientId":"fact-index-web-b","clientSecret":"secret-b","redirectUri":"http://localhost:5332/auth/federation/callback"}]}]
FEDERATION_OPS=

# ============================================================================
# OIDC Provider Configuration
# (only used if ENABLE_FEDERATION=true)
# ============================================================================
OIDC_BASE_URL=https://fact.example.com
OIDC_CLIENT_ID=fact-index
OIDC_CLIENT_SECRET=dev-secret-change-in-production
OIDC_REDIRECT_URI=http://localhost:5332/auth/federation/callback
OIDC_FRONTEND_REDIRECT_URI=http://localhost:5173/callback
SESSION_SECRET=dev-session-secret-change-in-production

# ============================================================================
# Discord OAuth Configuration
# ============================================================================
DISCORD_CLIENT_ID=your-discord-app-id
DISCORD_CLIENT_SECRET=your-discord-app-secret
DISCORD_CALLBACK_URL=http://localhost:5332/auth/discord/callback
DEV_LOGIN_MODE=false

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=sqlite3:./db/dev.sqlite3

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
