# ============================================================================
# Fact Index Frontend Configuration
# ============================================================================
# Copy this file to .env.local and update the values for your environment

# ============================================================================
# Client Configuration
# ============================================================================
NODE_ENV=development

# Backend API server URL
VITE_API_BASE_URL=http://localhost:5332

# ============================================================================
# OpenID Federation Configuration (for login with United Federation)
# ============================================================================
# OAuth 2.0 Client ID for this frontend (registered with the OIDC Provider)
VITE_OIDC_CLIENT_ID=fact-index-frontend

# OAuth 2.0 Redirect URI - must match server configuration
# Set to your frontend domain in production
VITE_OIDC_REDIRECT_URI=http://localhost:4300/oidc/callback

# Authorization endpoint on the OIDC Provider
# Leave as default to use server's .well-known/openid-federation endpoint
VITE_OIDC_AUTHORIZATION_ENDPOINT=/oidc/authorization

# Token endpoint for code exchange
VITE_OIDC_TOKEN_ENDPOINT=/oidc/token

# ============================================================================
# Other Configuration
# ============================================================================
VITE_HMR_PORT=24679
