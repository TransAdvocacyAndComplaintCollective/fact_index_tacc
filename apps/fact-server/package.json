{
  "name": "fact-server",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/main.ts",
  "onlyDependOnLibsWithTags": [
    "scope:shared-authorization",
    "scope:shared-db"
  ],
  "scripts": {
    "start": "NODE_ENV=production TS_NODE_PROJECT=tsconfig.json DOTENV_CONFIG_PATH=apps/fact-server/.env node -r tsconfig-paths/register -r @swc-node/register -r dotenv/config ./src/main.ts",
    "dev": "NODE_ENV=development TS_NODE_PROJECT=../../tsconfig.base.json TSCONFIG_PATHS_CONFIG_DIR=../.. node --watch --enable-source-maps -r tsconfig-paths/register -r @swc-node/register -r dotenv/config ./src/main.ts",
    "dev:hot_reload": "NODE_ENV=development node --watch --enable-source-maps -r tsconfig-paths/register -r @swc-node/register -r dotenv/config ./src/main.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "nx lint fact-server",
    "lint:ts": "tsc --noEmit -p tsconfig.app.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@factdb/db-core": "workspace:*",
    "@factdb/types": "workspace:*",
    "@openid-federation/core": "^0.2.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express-session": "^1.18.2",
    "@types/node": "latest",
    "@types/passport": "^1.0.17",
    "better-sqlite3": "^12.6.2",
    "casbin": "^5.48.0",
    "casbin-basic-adapter": "^1.3.0",
    "casbin-express-authz": "^3.0.1",
    "casbin-sequelize-adapter": "^2.7.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "i": "^0.3.7",
    "jose": "^6.1.3",
    "jsonwebtoken": "^9.0.3",
    "npm": "^11.10.0",
    "oidc-provider": "^9.6.0",
    "openid-client": "^6.8.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-magic-link": "^3.0.0",
    "sequelize": "^6.37.7"
