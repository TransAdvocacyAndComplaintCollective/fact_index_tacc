{
  "name": "fact-server",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "src/main.ts",
  "onlyDependOnLibsWithTags": [
    "scope:shared-authorization",
    "scope:shared-db"
  ],
  "scripts": {
    "start": "NODE_ENV=production TS_NODE_PROJECT=tsconfig.json DOTENV_CONFIG_PATH=apps/fact-server/.env node -r tsconfig-paths/register -r @swc-node/register -r dotenv/config ./src/main.ts",
    "dev": "NODE_ENV=development TS_NODE_PROJECT=tsconfig.json node --watch --enable-source-maps -r tsconfig-paths/register -r @swc-node/register -r dotenv/config ./src/main.ts",
    "dev:hot_reload": "NODE_ENV=development node --watch --enable-source-maps -r tsconfig-paths/register -r @swc-node/register -r dotenv/config ./src/main.ts",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "nx lint fact-server",
    "lint:ts": "tsc --noEmit -p tsconfig.app.json"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.25.0",
  "dependencies": {
    "@factdb/db-core": "workspace:*",
    "@factdb/types": "workspace:*",
    "@types/node": "latest",
    "@types/passport": "^1.0.17",
    "better-sqlite3": "^12.6.2",
    "jsonwebtoken": "^9.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-magic-link": "^3.0.0"
  }
}
