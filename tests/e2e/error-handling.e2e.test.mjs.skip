import { test } from 'node:test';
import assert from 'node:assert';
import express from 'express';
import request from 'supertest';
import { fileURLToPath } from 'url';
import path from 'path';
import fs from 'fs';
import { createWriteStream } from 'fs';

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

// ============================================================================
// ERROR HANDLER TESTS
// ============================================================================

test('Global Error Handler - Catches Unhandled Route Errors', async (t) => {
  // This test verifies that the global error handler catches errors thrown in routes
  // and returns a consistent error response format
  
  const app = express();
  
  // Simple middleware to set up the route before error handler
  app.get('/test-error', (req, res, next) => {
    next(new Error('Test error from route'));
  });
  
  // Simplified error handler (matches actual errorHandler.ts)
  app.use((err, req, res, next) => {
    const statusCode = err.statusCode || 500;
    res.status(statusCode).json({
      error: err.code || 'INTERNAL_SERVER_ERROR',
      message: err.message || 'An error occurred'
    });
  });
  
  const response = await request(app)
    .get('/test-error')
    .expect(500);
  
  assert.strictEqual(response.body.error, 'INTERNAL_SERVER_ERROR');
  assert(response.body.message.includes('Test error'));
});

test('Global Error Handler - Returns Consistent Format', async (t) => {
  // Verifies error responses follow a consistent format
  
  const app = express();
  
  app.get('/custom-error', (req, res, next) => {
    const err = new Error('Custom error message');
    err.statusCode = 400;
    err.code = 'VALIDATION_ERROR';
    next(err);
  });
  
  app.use((err, req, res, next) => {
    res.status(err.statusCode || 500).json({
      error: err.code || 'INTERNAL_SERVER_ERROR',
      message: err.message
    });
  });
  
  const response = await request(app)
    .get('/custom-error')
    .expect(400);
  
  assert.strictEqual(response.body.error, 'VALIDATION_ERROR');
  assert.strictEqual(response.body.message, 'Custom error message');
  assert(typeof response.body.error === 'string');
  assert(typeof response.body.message === 'string');
});

test('Global Error Handler - Prevents Double Response', async (t) => {
  // Verifies that error handler won't try to send response if headers already sent
  
  const app = express();
  
  app.get('/double-response', (req, res, next) => {
    res.json({ success: true });
    // Simulate error after headers sent
    next(new Error('Error after response'));
  });
  
  app.use((err, req, res, next) => {
    // Check if headers already sent
    if (res.headersSent) {
      return;  // Don't try to send response again
    }
    res.status(500).json({ error: 'INTERNAL_SERVER_ERROR' });
  });
  
  const response = await request(app)
    .get('/double-response')
    .expect(200);
  
  assert.strictEqual(response.body.success, true);
});

test('Global Error Handler - Handles AppError with statusCode', async (t) => {
  // Tests that custom AppError instances are handled correctly
  
  class AppError extends Error {
    constructor(message, statusCode = 500, code = 'INTERNAL_SERVER_ERROR') {
      super(message);
      this.statusCode = statusCode;
      this.code = code;
    }
  }
  
  const app = express();
  
  app.get('/app-error', (req, res, next) => {
    next(new AppError('Not found', 404, 'NOT_FOUND'));
  });
  
  app.use((err, req, res, next) => {
    const statusCode = err.statusCode || 500;
    const code = err.code || 'INTERNAL_SERVER_ERROR';
    res.status(statusCode).json({
      error: code,
      message: err.message
    });
  });
  
  const response = await request(app)
    .get('/app-error')
    .expect(404);
  
  assert.strictEqual(response.body.error, 'NOT_FOUND');
});

// ============================================================================
// withErrorHandling WRAPPER TESTS
// ============================================================================

test('withErrorHandling - Catches Promise Rejections', async (t) => {
  // Verifies that async route handlers have Promise rejections caught
  
  const app = express();
  
  // Simulated withErrorHandling wrapper
  const withErrorHandling = (fn) => (req, res, next) => {
    Promise.resolve(fn(req, res, next)).catch(next);
  };
  
  app.get('/async-error', withErrorHandling(async (req, res) => {
    throw new Error('Async operation failed');
  }));
  
  app.use((err, req, res, next) => {
    res.status(500).json({
      error: 'INTERNAL_SERVER_ERROR',
      message: err.message
    });
  });
  
  const response = await request(app)
    .get('/async-error')
    .expect(500);
  
  assert(response.body.message.includes('Async operation failed'));
});

test('withErrorHandling - Passes Through Successful Results', async (t) => {
  // Verifies wrapper doesn't interfere with normal operation
  
  const app = express();
  
  const withErrorHandling = (fn) => (req, res, next) => {
    Promise.resolve(fn(req, res, next)).catch(next);
  };
  
  app.get('/async-success', withErrorHandling(async (req, res) => {
    const result = await Promise.resolve({ success: true });
    res.json(result);
  }));
  
  const response = await request(app)
    .get('/async-success')
    .expect(200);
  
  assert.strictEqual(response.body.success, true);
});

test('withErrorHandling - Executes Function Correctly', async (t) => {
  // Verifies the wrapped function is actually called
  
  let functionCalled = false;
  
  const app = express();
  
  const withErrorHandling = (fn) => (req, res, next) => {
    Promise.resolve(fn(req, res, next)).catch(next);
  };
  
  app.get('/test', withErrorHandling(async (req, res) => {
    functionCalled = true;
    res.json({ executed: true });
  }));
  
  await request(app)
    .get('/test')
    .expect(200);
  
  assert.strictEqual(functionCalled, true);
});

// ============================================================================
// buildErrorHandler TESTS
// ============================================================================

test('buildErrorHandler - Creates Route-Specific Error Handler', async (t) => {
  // Verifies that route-specific error handler formats errors correctly
  
  const buildErrorHandler = (routeName) => {
    return (res, error, context = {}) => {
      const statusCode = error.statusCode || 500;
      res.status(statusCode).json({
        error: error.code || 'INTERNAL_SERVER_ERROR',
        message: error.message,
        route: routeName,
        ...(Object.keys(context).length > 0 && { context })
      });
    };
  };
  
  const app = express();
  
  app.get('/api/facts', (req, res) => {
    try {
      throw new Error('Database connection failed');
    } catch (err) {
      const handler = buildErrorHandler('GET /api/facts');
      handler(res, err, { attemptNumber: 1 });
    }
  });
  
  const response = await request(app)
    .get('/api/facts')
    .expect(500);
  
  assert.strictEqual(response.body.route, 'GET /api/facts');
  assert.strictEqual(response.body.context.attemptNumber, 1);
});

test('buildErrorHandler - Includes Error Context', async (t) => {
  // Verifies context information is included in error response
  
  const buildErrorHandler = (routeName) => {
    return (res, error, context = {}) => {
      res.status(error.statusCode || 500).json({
        error: error.code || 'INTERNAL_SERVER_ERROR',
        message: error.message,
        ...(Object.keys(context).length > 0 && { context })
      });
    };
  };
  
  const app = express();
  
  app.post('/api/facts', (req, res) => {
    try {
      throw new Error('Validation failed');
    } catch (err) {
      const handler = buildErrorHandler('POST /api/facts');
      handler(res, err, { 
        field: 'fact_text',
        reason: 'Too short'
      });
    }
  });
  
  const response = await request(app)
    .post('/api/facts')
    .expect(500);
  
  assert.strictEqual(response.body.context.field, 'fact_text');
  assert.strictEqual(response.body.context.reason, 'Too short');
});

// ============================================================================
// safeLoadConfig TESTS
// ============================================================================

test('safeLoadConfig - Loads Valid Config Successfully', async (t) => {
  // Verifies configuration loads correctly from valid source
  
  const safeLoadConfig = async (loader, fallback) => {
    try {
      return await loader();
    } catch (err) {
      return fallback;
    }
  };
  
  const testConfig = { users: ['alice', 'bob'], roles: { admin: true } };
  
  const result = await safeLoadConfig(
    async () => testConfig,
    { users: [], roles: {} }
  );
  
  assert.deepStrictEqual(result, testConfig);
});

test('safeLoadConfig - Returns Fallback on Load Error', async (t) => {
  // Verifies fallback is returned when loading fails
  
  const safeLoadConfig = async (loader, fallback) => {
    try {
      return await loader();
    } catch (err) {
      return fallback;
    }
  };
  
  const fallbackConfig = { users: [], roles: {} };
  
  const result = await safeLoadConfig(
    async () => {
      throw new Error('File not found');
    },
    fallbackConfig
  );
  
  assert.deepStrictEqual(result, fallbackConfig);
});

test('safeLoadConfig - Preserves Error in Logging Scenario', async (t) => {
  // Verifies error is caught but can be logged
  
  const safeLoadConfig = async (loader, fallback) => {
    let error = null;
    try {
      return await loader();
    } catch (err) {
      error = err;
      return fallback;
    }
  };
  
  // In real implementation, error would be logged before returning fallback
  let configError = null;
  const result = await safeLoadConfig(
    async () => {
      throw new Error('Corrupt JSON');
    },
    { users: [] }
  );
  
  // Verify we got fallback
  assert.deepStrictEqual(result, { users: [] });
});

// ============================================================================
// safeSaveConfig TESTS
// ============================================================================

test('safeSaveConfig - Saves Config Successfully', async (t) => {
  // Verifies configuration saves without error
  
  const safeSaveConfig = async (saver, validator) => {
    try {
      await saver();
      return true;
    } catch (err) {
      return false;
    }
  };
  
  const saved = await safeSaveConfig(
    async () => {
      // Simulate successful save
      return;
    },
    undefined
  );
  
  assert.strictEqual(saved, true);
});

test('safeSaveConfig - Returns False on Save Error', async (t) => {
  // Verifies error during save is handled
  
  const safeSaveConfig = async (saver, validator) => {
    try {
      await saver();
      return true;
    } catch (err) {
      return false;
    }
  };
  
  const saved = await safeSaveConfig(
    async () => {
      throw new Error('Permission denied');
    },
    undefined
  );
  
  assert.strictEqual(saved, false);
});

test('safeSaveConfig - Validates Before Saving', async (t) => {
  // Verifies validator is called before save
  
  let validationCalled = false;
  
  const safeSaveConfig = async (saver, validator) => {
    try {
      if (validator) {
        await validator();
      }
      validationCalled = !!validator;
      await saver();
      return true;
    } catch (err) {
      return false;
    }
  };
  
  await safeSaveConfig(
    async () => {},
    async () => {
      // Validation function
    }
  );
  
  assert.strictEqual(validationCalled, true);
});

test('safeSaveConfig - Prevents Invalid Config Save', async (t) => {
  // Verifies that invalid config is not saved
  
  const safeSaveConfig = async (saver, validator) => {
    try {
      if (validator) {
        const isValid = await validator();
        if (!isValid) {
          throw new Error('Validation failed');
        }
      }
      await saver();
      return true;
    } catch (err) {
      return false;
    }
  };
  
  const saved = await safeSaveConfig(
    async () => {
      throw new Error('Should not be called');
    },
    async () => false  // Validation fails
  );
  
  assert.strictEqual(saved, false);
});

