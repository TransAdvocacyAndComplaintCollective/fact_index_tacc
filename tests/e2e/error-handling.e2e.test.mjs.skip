test('ensureDbConnection - Returns Connection When Valid', async (t) => {
  // Verifies valid database connection is returned
  
  const ensureDbConnection = async (getter) => {
    const db = getter();
    if (!db) {
      throw new Error('Database not initialized');
    }
    return db;
  };
  
  const mockDb = { query: () => { } };
  
  const result = await ensureDbConnection(() => mockDb);
  
  assert.strictEqual(result, mockDb);
});

test('ensureDbConnection - Throws When DB is Null', async (t) => {
  // Verifies error is thrown when database is not initialized
  
  const ensureDbConnection = async (getter) => {
    const db = getter();
    if (!db) {
      throw new Error('Database not initialized');
    }
    return db;
  };
  
  try {
    await ensureDbConnection(() => null);
    assert.fail('Should have thrown error');
  } catch (err) {
    assert(err.message.includes('Database not initialized'));
  }
});

test('ensureDbConnection - Throws When DB is Undefined', async (t) => {
  // Verifies error is thrown when database getter returns undefined
  
  const ensureDbConnection = async (getter) => {
    const db = getter();
    if (!db) {
      throw new Error('Database not initialized');
    }
    return db;
  };
  
  try {
    await ensureDbConnection(() => undefined);
    assert.fail('Should have thrown error');
  } catch (err) {
    assert(err.message.includes('Database not initialized'));
  }
});

// ============================================================================
// Error Response Format TESTS
// ============================================================================

test('Error Response - Contains Required Fields', async (t) => {
  // Verifies error response has all required fields
  
  const app = express();
  
  app.get('/error', (req, res, next) => {
    next(new Error('Test error'));
  });
  
  app.use((err, req, res, next) => {
    res.status(500).json({
      error: 'INTERNAL_SERVER_ERROR',
      message: err.message
    });
  });
  
  const response = await request(app)
    .get('/error')
    .expect(500);
  
  assert(response.body.hasOwnProperty('error'));
  assert(response.body.hasOwnProperty('message'));
  assert.strictEqual(typeof response.body.error, 'string');
  assert.strictEqual(typeof response.body.message, 'string');
});

test('Error Response - Can Include Optional Details', async (t) => {
  // Verifies optional fields can be included in error response
  
  const app = express();
  
  app.get('/error', (req, res, next) => {
    const err = new Error('Validation failed');
    err.statusCode = 400;
    err.code = 'VALIDATION_ERROR';
    err.details = { field: 'email', reason: 'Invalid format' };
    next(err);
  });
  
  app.use((err, req, res, next) => {
    const response = {
      error: err.code || 'INTERNAL_SERVER_ERROR',
      message: err.message
    };
    if (err.details) {
      response.details = err.details;
    }
    res.status(err.statusCode || 500).json(response);
  });
  
  const response = await request(app)
    .get('/error')
    .expect(400);
  
  assert.strictEqual(response.body.details.field, 'email');
});

test('Error Response - Different HTTP Status Codes', async (t) => {
  // Verifies different status codes are returned correctly
  
  const testCases = [
    { code: 'VALIDATION_ERROR', status: 400 },
    { code: 'NOT_FOUND', status: 404 },
    { code: 'UNAUTHORIZED', status: 401 },
    { code: 'FORBIDDEN', status: 403 },
    { code: 'INTERNAL_SERVER_ERROR', status: 500 }
  ];
  
  for (const testCase of testCases) {
    const app = express();
    
    app.get('/error', (req, res, next) => {
      const err = new Error('Test error');
      err.statusCode = testCase.status;
      err.code = testCase.code;
      next(err);
    });
    
    app.use((err, req, res, next) => {
      res.status(err.statusCode || 500).json({
        error: err.code,
        message: err.message
      });
    });
    
    const response = await request(app)
      .get('/error')
      .expect(testCase.status);
    
    assert.strictEqual(response.body.error, testCase.code);
    assert.strictEqual(response.status, testCase.status);
  }
});

// ============================================================================
// INTEGRATION TESTS - Multiple Operations
// ============================================================================

test('Error Handling Integration - Multiple Sequential Errors', async (t) => {
  // Verifies error handler works correctly across multiple requests
  
  const app = express();
  let errorCount = 0;
  
  app.get('/error', (req, res, next) => {
    next(new Error('Sequential error'));
  });
  
  app.use((err, req, res, next) => {
    errorCount++;
    res.status(500).json({
      error: 'INTERNAL_SERVER_ERROR',
      message: err.message,
      errorNumber: errorCount
    });
  });
  
  // First error
  const response1 = await request(app)
    .get('/error')
    .expect(500);
  assert.strictEqual(response1.body.errorNumber, 1);
  
  // Second error
  const response2 = await request(app)
    .get('/error')
    .expect(500);
  assert.strictEqual(response2.body.errorNumber, 2);
});

test('Error Handling Integration - Errors with Context Tracking', async (t) => {
  // Verifies context information is maintained across error handling
  
  const app = express();
  
  app.get('/api/users/:id/posts', (req, res, next) => {
    try {
      const userId = parseInt(req.params.id);
      if (isNaN(userId)) {
        const err = new Error('Invalid user ID');
        err.statusCode = 400;
        err.code = 'VALIDATION_ERROR';
        err.context = { field: 'id', value: req.params.id };
        throw err;
      }
      // Simulate processing
      throw new Error('Database connection failed');
    } catch (err) {
      next(err);
    }
  });
  
  app.use((err, req, res, next) => {
    const response = {
      error: err.code || 'INTERNAL_SERVER_ERROR',
      message: err.message,
      path: req.path
    };
    if (err.context) {
      response.context = err.context;
    }
    res.status(err.statusCode || 500).json(response);
  });
  
  const response = await request(app)
    .get('/api/users/invalid/posts')
    .expect(400);
  
  assert.strictEqual(response.body.error, 'VALIDATION_ERROR');
  assert.strictEqual(response.body.context.value, 'invalid');
});

test('Error Handling Integration - Middleware Chain with Error Handler', async (t) => {
  // Verifies error handler correctly intercepts errors from any middleware
  
  const app = express();
  
  // First middleware
  app.use((req, res, next) => {
    req.user = { id: 1 };
    next();
  });
  
  // Route that throws
  app.get('/protected', (req, res, next) => {
    if (!req.user) {
      const err = new Error('Unauthorized');
      err.statusCode = 401;
      err.code = 'UNAUTHORIZED';
      return next(err);
    }
    res.json({ message: 'Success' });
  });
  
  // Error handler
  app.use((err, req, res, next) => {
    res.status(err.statusCode || 500).json({
      error: err.code || 'INTERNAL_SERVER_ERROR',
      message: err.message
    });
  });
  
  const response = await request(app)
    .get('/protected')
    .expect(200);
  
  assert.strictEqual(response.body.message, 'Success');
});

// ============================================================================
// EDGE CASE TESTS
// ============================================================================

test('Error Handler - Handles Non-Error Objects', async (t) => {
  // Verifies handler works when non-Error objects are thrown
  
  const app = express();
  
  app.get('/error', (req, res, next) => {
    // Throwing a string instead of Error
    next('Something went wrong');
  });
  
  app.use((err, req, res, next) => {
    const message = err instanceof Error ? err.message : String(err);
    res.status(500).json({
      error: 'INTERNAL_SERVER_ERROR',
      message: message
    });
  });
  
  const response = await request(app)
    .get('/error')
    .expect(500);
  
  assert.strictEqual(response.body.message, 'Something went wrong');
});

test('Error Handler - Gracefully Handles Missing Message', async (t) => {
  // Verifies handler works when error has no message
  
  const app = express();
  
  app.get('/error', (req, res, next) => {
    const err = new Error();
    err.statusCode = 500;
    next(err);
  });
  
  app.use((err, req, res, next) => {
    res.status(err.statusCode || 500).json({
      error: 'INTERNAL_SERVER_ERROR',
      message: err.message || 'An error occurred'
    });
  });
  
  const response = await request(app)
    .get('/error')
    .expect(500);
  
  assert(response.body.message);  // Should have some message
});

test('Error Handler - Handles Null/Undefined Status Code', async (t) => {
  // Verifies correct default status code is used
  
  const app = express();
  
  app.get('/error', (req, res, next) => {
    const err = new Error('Some error');
    // No statusCode set
    next(err);
  });
  
  app.use((err, req, res, next) => {
    res.status(err.statusCode || 500).json({
      error: 'INTERNAL_SERVER_ERROR',
      message: err.message
    });
  });
  
  const response = await request(app)
    .get('/error')
    .expect(500);
  
  assert.strictEqual(response.status, 500);
});

