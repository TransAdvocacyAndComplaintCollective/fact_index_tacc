# 🚫 Node.js dependencies (ignore all node_modules in any workspace)
node_modules/

# 🧪 Build output directories
/backend/build/
/frontend/dist/
/common/dist/
/build/
/dist/

# 📝 Lock and package manager files
package-lock.json
yarn.lock

# 📦 Parcel cache
/**/.parcel-cache/
/**/.cache/
/**/dist/

# 🔐 Env files
.env
.env.local
.env.*.local

# 🔍 Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log

# ✅ Test coverage
coverage/
**/coverage/

# ⚙️ ESLint, Prettier, Jest caches
.eslintcache
.cache/
jest.config.js
jest-*.config.js

# 🧊 Editor files
.vscode/
.idea/
*.sublime-*
*.swp
.DS_Store

# 🧬 TypeScript artifacts
frontend/**/*.tsbuildinfo
/common/**/*.tsbuildinfo
backend/**/*.tsbuildinfo

# 🛠 Miscellaneous files
*.tgz
*.pnp.*
.yarn/*
!.yarn/cache
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
