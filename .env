DISCORD_GUILD_ID=2333
DISCORD_CLIENT_ID=your_bot_client_id
DISCORD_CLIENT_SECRET=your_bot_secret
DISCORD_CALLBACK_URL=https://yourdomain/auth/discord/callback
DISCORD_ROLE_ID=12345 


# Enables or disables dev login feature
DEV_ENABLED=true
# Secret key used to sign and verify JWT tokens for dev login
DEV_JWT_SECRET=your_super_secret_key_here
# Username shown for the dev user (optional, defaults to 'DevUser' if missing)
DEV_USERNAME=DevUser
# Avatar URL or null for the dev user (optional)
DEV_AVATAR=null

DEV_LOGIN_MODE=TRUE
DEBUG_REACT=TRUE
PORT=16261
